# MatchFlow web app — serverless config (no Firebase needed).
# Copy to .env.local for local dev, or set these in Vercel project settings.

# Gemini API key used by /api/concierge and /api/rank-egress serverless routes.
# NEVER commit the real key. Put the production key in Vercel env (not here).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Vercel KV (optional — the app falls back to in-memory storage if unset).
# After creating a KV store in the Vercel dashboard, these are auto-injected.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_URL=
